{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_DISABLE_GIT_INSTRUCTIONS": "1",
    "DISABLE_AUTOUPDATER": "1"
  },
  "permissions": {
    "allow": [
      "Bash(cargo:*)"
    ],
    "deny": [
      "Read(**/.env*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.cert)",
      "Read(**/*.crt)",
      "Read(**/secrets.yml)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "excludedCommands": [
      "cargo:*"
    ]
  },
  "statusLine": {
    "command": "~/.claude/statusline.sh",
    "type": "command"
  }
}
